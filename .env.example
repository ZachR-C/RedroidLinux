# Copy to .env and adjust if needed. All optional — sane defaults in config.js.
PORT=8080
WS_SCRCPY_PORT=8000
# Comma-separated redroid images offered in the create dialog (arm64 tags).
# Use _64only on Apple Silicon / pure-ARMv8 hosts (no 32-bit ARM mode).
REDROID_IMAGES=redroid/redroid:13.0.0_64only-latest,redroid/redroid:12.0.0_64only-latest
# ADB port range allocated to instances (one per device).
ADB_PORT_BASE=5555
ADB_PORT_MAX=5700

# Remote ADB access (how other computers reach this server). Optional — the UI
# auto-detects the host IP and lets you edit host/user per connection.
# On a VPS set PUBLIC_HOST to your domain/public IP.
PUBLIC_HOST=
SSH_USER=
SSH_PORT=22
